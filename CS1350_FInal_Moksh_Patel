def gradebook_summary(grades):
    student_averages = {}
    course_scores = {}
    course_student_averages = {}

    for student, courses in grades.items():
        all_scores = []
        for course, scores in courses.items():
            all_scores.extend(scores)
            course_scores[course] = course_scores.get(course, []) + scores
            
            if course not in course_student_averages:
                course_student_averages[course] = {}
            course_student_averages[course][student] = sum(scores) / len(scores)
        student_averages[student] = sum(all_scores) / len(all_scores)
    course_averages = {
        course: sum(scores) / len(scores)
        for course, scores in course_scores.items()
    }

    top_per_course = {}
    for course, student_avgs in course_student_averages.items():
        top_student = min(student_avgs, key=lambda s: (-student_avgs[s], s))
        top_per_course[course] = top_student

    return {
        "student_averages": student_averages,
        "course_averages": course_averages,
        "top_per_course": top_per_course,
    }



def skill_analysis(candidates, required):
    fully_qualified = sorted(
        name for name, skills in candidates.items()
        if required <= skills
    )
    best_match = min(
        candidates,
        key=lambda name: (-len(candidates[name] & required), name)
    )

    all_others_union = {}
    for name, skills in candidates.items():
        others = set().union(*(s for n, s in candidates.items() if n != name))
        all_others_union[name] = others
    unique_skills = {
        name: sorted(candidates[name] - all_others_union[name])
        for name in candidates
        if candidates[name] - all_others_union[name]
    }
    return {
        "fully_qualified": fully_qualified,
        "best_match": best_match,
        "unique_skills": unique_skills,
    }


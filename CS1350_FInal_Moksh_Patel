def subset_sum(nums, target):
    if target == 0:
        return True
    if not nums:
        return False

    return subset_sum(nums[1:], target - nums[0]) or subset_sum(nums[1:], target)


print(subset_sum([3, 34, 4, 12, 5, 2], 9))
print(subset_sum([3, 34, 4, 12, 5, 2], 30))
print(subset_sum([1, 2, 3], 0))
print(subset_sum([], 0))

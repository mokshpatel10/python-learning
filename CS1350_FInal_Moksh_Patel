import re

HASHTAG_RE = re.compile(r'#(\w+)')
MENTION_RE = re.compile(r'@(\w+)')
URL_RE = re.compile(r'https?://\S+')

def parse_post(text):
    def dedupe(items):
        seen = {}
        return list(seen.fromkeys(items))

    return {
        "hashtags": dedupe(HASHTAG_RE.findall(text)),
        "mentions": dedupe(MENTION_RE.findall(text)),
        "urls":     dedupe(URL_RE.findall(text)),
    }
